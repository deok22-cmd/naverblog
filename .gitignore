# 로컬 운영 스크립트 로그
.scripts/logs/

# Claude Code 로컬 설정
.claude/settings.local.json

# 인스타 래스터화 도구 (Node deps — 커밋 제외)
node_modules/
package-lock.json

# 시크릿 (절대 커밋 금지) — GEMINI_API_KEY 등
.scripts/secret.env.ps1

# 인스타 대용량 산출물 (재생성 가능 — 리포 비대화 방지, 로컬 보관/업로드용)
output_insta/**/img/
output_insta/**/*_done.svg
output_insta/**/png/

# 인스타 재구성 전 로컬 안전 백업 (임시·로컬 전용 — 커밋 제외)
output_insta/**/_backup_pre_recompose/
